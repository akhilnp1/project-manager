{
  "info": {
    "name": "Project Manager API",
    "description": "Full CRUD API for Project Manager — FastAPI + PostgreSQL",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();", "if (r.access_token) pm.collectionVariables.set('token', r.access_token);"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Developer\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"developer\"\n}" }
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/users?page=1&size=10", "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }] }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/1"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/users/2",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Smith\",\n  \"role\": \"developer\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/projects",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Website Redesign\",\n  \"description\": \"Redesign the company website with modern UI\"\n}" }
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/projects?page=1&size=10", "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }] }
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/projects/1"
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/projects/1",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Website Redesign v2\",\n  \"description\": \"Updated scope\"\n}" }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/projects/1"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Design homepage mockup\",\n  \"description\": \"Create Figma wireframes for the new homepage\",\n  \"project_id\": 1,\n  \"assigned_to\": 2,\n  \"due_date\": \"2025-12-31\",\n  \"status\": \"todo\"\n}" }
          }
        },
        {
          "name": "List Tasks (all)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tasks?page=1&size=10", "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }] }
          }
        },
        {
          "name": "List Tasks (filter by project)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tasks?project_id=1", "query": [{ "key": "project_id", "value": "1" }] }
          }
        },
        {
          "name": "List Tasks (filter by status)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tasks?status=in_progress", "query": [{ "key": "status", "value": "in_progress" }] }
          }
        },
        {
          "name": "List Tasks (filter by assignee)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/tasks?assigned_to=2", "query": [{ "key": "assigned_to", "value": "2" }] }
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks/1"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks/1",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Updated title\",\n  \"due_date\": \"2026-01-15\"\n}" }
          }
        },
        {
          "name": "Assign Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks/1/assign",
            "body": { "mode": "raw", "raw": "{\n  \"assigned_to\": 2\n}" }
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks/1/status",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"in_progress\"\n}" }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/tasks/1"
          }
        }
      ]
    }
  ]
}
